DISCORD_TOKEN=replace-me
AMADEUS_OWNER_ID=

# Comma-separated module cogs to load. Matching *_admin cogs are auto-loaded.
# Examples:
# AMADEUS_COGS=cogs.bouncer,cogs.honeypot
# AMADEUS_COGS=cogs.boost,cogs.activity
AMADEUS_COGS=
AMADEUS_DB_PATH=/app/data/amadeus.sqlite3
AMADEUS_PRIVACY_POLICY_URL=
AMADEUS_TERMS_OF_SERVICE_URL=

AMADEUS_MIN_ACCOUNT_AGE_DAYS=14
AMADEUS_MAX_FAILED_ATTEMPTS=3
AMADEUS_CAPTCHA_LENGTH=6
AMADEUS_CAPTCHA_EXPIRY_MINUTES=10
AMADEUS_BACKFILL_DELAY_SECONDS=1.5
AMADEUS_VERIFICATION_ROLE_DELAY_SECONDS=5
AMADEUS_BACKFILL_INCLUDE_BOTS_BY_DEFAULT=false

AMADEUS_LOG_LEVEL=INFO
AMADEUS_DISCORD_LOG_LEVEL=WARNING

# Development: set to true and provide a guild ID for fast guild-scoped command syncing.
AMADEUS_DEBUG=false
AMADEUS_DEBUG_SERVER_ID=
